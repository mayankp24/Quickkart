<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <style>
        .hvr:hover{
            cursor:pointer;
        }
    </style>
</head>

<body class="bg-zinc-900 text-white" style="font-family: Arial, Helvetica, sans-serif;">
   <%var loggedin = typeof loggedin === "undefined" ? 1 : loggedin%>
   <nav class="w-full px-5 py-3 flex justify-between items-center bg-zinc-900">
  <!-- Logo + Brand -->
  <div class="flex items-center gap-3">
    <img src="/images/logo.png" alt="Quickkart Logo" class="h-12 w-auto  p-1 rounded" />
    <h3 class="text-2xl font-bold text-white"><span class="text-blue-400 font-semibold">Quickkart</span></h3>
  </div>

  <!-- Navigation Links -->
  <div class="flex gap-4 items-center">
    <% if (loggedin !== 0) { %>
      <% if (loggedin === 1) { %>
        <a href="/shop"
          class="px-3 py-2 rounded-md transition-all duration-200 hvr
          <% if (activeRoute === '/shop') { %> bg-white text-black <% } else { %> text-white hover:bg-white/10 <% } %>">
          Shop <i class="fa-solid fa-shop ml-1"></i>
        </a>
        <a href="/cart"
          class="px-3 py-2 rounded-md transition-all duration-200 hvr
          <% if (activeRoute === '/cart') { %> bg-white text-black <% } else { %> text-white hover:bg-white/10 <% } %>">
          Cart <i class="fa-solid fa-cart-shopping ml-1"></i>
        </a>
        <a href="/users/account"
          class="px-3 py-2 rounded-md transition-all duration-200 hvr
          <% if (activeRoute === '/users/account') { %> bg-white text-black <% } else { %> text-white hover:bg-white/10 <% } %>">
          My Account <i class="fa-solid fa-user ml-1"></i>
        </a>
      <% } %>
      <a href="/users/logout"
        class="px-3 py-2 rounded-md text-red-500 hover:bg-red-500/10 transition-all duration-200 hvr">
        Logout <i class="fa-solid fa-right-from-bracket ml-1"></i>
      </a>
    <% } %>
  </div>
</nav>
