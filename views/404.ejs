<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>404 - Page Not Found</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 text-white flex items-center justify-center h-screen">
    <div class="text-center px-4">
        <h1 class="text-7xl font-bold text-blue-500 mb-4">404</h1>
        <h2 class="text-3xl font-semibold mb-2">Page Not Found</h2>
        <p class="text-lg text-zinc-300 mb-6">Sorry, the page you're looking for doesn't exist or has been removed.</p>
        <a href="/" class="inline-block px-6 py-3 bg-blue-600 rounded-full text-white font-medium hover:bg-blue-700 transition duration-300">
            Return to Homepage
        </a>
    </div>
</body>
</html>
