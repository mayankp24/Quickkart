<%- include('./partials/header') %>

<div class="w-full min-h-screen bg-zinc-900 px-20 py-10">
    <h2 class="text-3xl font-semibold text-white mb-8 border-b-2 border-zinc-700 pb-2">Your Profile</h2>

    <div class="bg-zinc-800 shadow-xl rounded-2xl flex p-10 gap-10">
        <!-- Profile Picture -->
        <div class="w-1/3 flex flex-col items-center">
            <div class="w-52 h-52 rounded-full overflow-hidden bg-zinc-700 border-4 border-zinc-600">
                <img class="object-cover w-full h-full"
                     src="data:image/jpeg;base64,<%= user.picture ? user.picture.toString('base64') : '' %>"
                    alt="Profile Picture">
            </div>

            <!-- Pencil Button to Toggle Form -->
            <button id="toggleFormBtn" class="bg-zinc-700 mt-2 rounded-md px-3 py-2 text-white transition">
                <i id="pencilIcon" class="fa-solid fa-pencil"></i>
            </button>

            <!-- Upload Form -->
            <form id="uploadForm" action="/users/changepic" method="POST" enctype="multipart/form-data" class="mt-6 w-full flex flex-col items-center gap-4 hidden">
                <input required type="file" name="profpic" accept="image/*" class="text-sm text-white bg-zinc-700 border border-zinc-600 rounded px-3 py-2 w-full">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded shadow">
                    Upload Photo
                </button>
            </form>
        </div>

        <!-- Profile Info -->
        <div class="w-2/3 flex flex-col justify-center text-zinc-200">
            <div class="mb-6">
                <h3 class="text-xl font-semibold text-zinc-300">Full Name</h3>
                <p class="text-lg text-zinc-400 mt-1"><%= user.fullname %></p>
            </div>

            <div class="mb-6">
                <h3 class="text-xl font-semibold text-zinc-300">Email</h3>
                <p class="text-lg text-zinc-400 mt-1"><%= user.email %></p>
            </div>

            <div class="mb-6">
                <h3 class="text-xl font-semibold text-zinc-300">Contact Number</h3>
                <p class="text-lg text-zinc-400 mt-1"><%= user.contact %></p>
            </div>
        </div>
    </div>
</div>

<script>
    const toggleBtn = document.getElementById('toggleFormBtn');
    const uploadForm = document.getElementById('uploadForm');
    const pencilIcon = document.getElementById('pencilIcon');

    toggleBtn.addEventListener('click', () => {
        uploadForm.classList.toggle('hidden');
        // Toggle pencil icon color
        if (uploadForm.classList.contains('hidden')) {
            pencilIcon.classList.remove('text-blue-500');
        } else {
            pencilIcon.classList.add('text-blue-500');
        }
    });
</script>

<%- include('./partials/footer') %>
