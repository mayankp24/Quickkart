<%- include('./partials/header') %>

<% if (user.cart.length === 0) { %>
  <div class="text-center text-2xl mt-20">Your cart is empty.</div>
<% } else { %>
  <div class="w-full px-20 py-10 flex flex-wrap gap-8 justify-start">
    <% user.cart.forEach(function(item) { %>      
      <div class="w-[23%] rounded-md overflow-hidden shadow-md">
        <div class="w-full h-52 flex justify-center items-center bg-[<%= item.product.bgcolor %>]">
          <img class="h-[10rem]" src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>" alt="">
        </div>
        <div class="w-full px-4 py-3 bg-[<%= item.product.panelcolor %>] text-[<%= item.product.textcolor %>]">
          <div class="flex justify-between items-center mb-2">
            <h3 class="font-semibold"><%= item.product.name %></h3>
            <h4 class="font-semibold">₹ <%= item.product.price %></h4>
            <h5 >Qty: <%= item.quantity %></h5>            
          </div>
          <div class="flex justify-between items-center">
            <div class="text-sm">
                <% if (item.product.discount > 0) { %>
              <h5 class="bg-green-300 text-xs font-semibold rounded px-2 py-0.5 text-black">
                -<%= ((100 * item.product.discount) / item.product.price).toFixed(2) %>%
              </h5>
            <% } %>
            </div>
            <div class="flex items-center gap-2">
              <a href="/cart/increase/<%= item.product._id %>" class="w-6 h-6 bg-white rounded-full flex items-center justify-center text-black">
                <i class="ri-add-line"></i>
              </a>
              <a href="/cart/decrease/<%= item.product._id %>" class="w-6 h-6 bg-white rounded-full flex items-center justify-center text-black">
                <i class="ri-subtract-line"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
  <% if (user.cart.length > 0) { %>
 <div class="px-20 mb-20 w-full">
  <h2 class="text-2xl font-semibold mb-4 text-white">Final Bill Summary</h2>
  <table class="w-full border border-zinc-700 text-left text-sm bg-zinc-800 text-zinc-100 rounded-md overflow-hidden">
    <thead class="bg-zinc-700 text-zinc-100">
      <tr>
        <th class="border border-zinc-700 px-4 py-2">S.No</th>
        <th class="border border-zinc-700 px-4 py-2">Item Name</th>
        <th class="border border-zinc-700 px-4 py-2">MRP (per item)</th>
        <th class="border border-zinc-700 px-4 py-2">Discount</th>
        <th class="border border-zinc-700 px-4 py-2">Quantity</th>
        <th class="border border-zinc-700 px-4 py-2">Final Price</th>
      </tr>
    </thead>
    <tbody>
      <% let total = 0; %>
      <% user.cart.forEach(function(item, index) { 
        let discount = item.product.discount;
        let price = item.product.price;
        let qty = item.quantity;
        let final = qty * (price - discount);
        total += final;
      %>
        <tr class="hover:bg-zinc-700 transition">
          <td class="border border-zinc-700 px-4 py-2"><%= index + 1 %></td>
          <td class="border border-zinc-700 px-4 py-2"><%= item.product.name %></td>
          <td class="border border-zinc-700 px-4 py-2">₹ <%= price %></td>
          <td class="border border-zinc-700 px-4 py-2">₹ <%= discount %></td>
          <td class="border border-zinc-700 px-4 py-2"><%= qty %></td>
          <td class="border border-zinc-700 px-4 py-2 font-semibold text-green-400">₹ <%= final %></td>
        </tr>
      <% }) %>
      <tr class="bg-green-900 text-green-300 font-bold">
        <td colspan="5" class="border border-zinc-700 px-4 py-2 text-right">Total Amount</td>
        <td class="border border-zinc-700 px-4 py-2">₹ <%= total %></td>
      </tr>
    </tbody>
  </table>
</div>

<% } %>

<% } %>

<%- include('./partials/footer') %>
