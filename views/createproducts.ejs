<%- include('./partials/header') %>

<% if(success.length > 0) { %>
  <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
    <span class="inline-block mt-1 mb-1 text-white">
      <%= success %>
    </span>
  </div>
<% } %>

<div class="min-h-screen bg-zinc-900 text-white flex flex-col">
  <div class="container px-10 py-20 flex flex-grow">
    <!-- Sidebar -->
    <div class="w-[25%] flex flex-col items-start bg-zinc-800 rounded-lg p-5 h-fit shadow-md">
      <h3 class="text-xl font-semibold mb-4">Owner Panel</h3>
      <div class="flex flex-col gap-3 w-full">
        <a href="/owners/allproducts"
           class="w-full px-4 py-2 rounded-md text-left hover:bg-zinc-700 transition 
           <% if (activeRoute === '/owners/allproducts') { %> bg-blue-500 text-white <% } else { %> text-gray-200 <% } %>">
          All Products
        </a>
        <a href="/owners/admin"
           class="w-full px-4 py-2 rounded-md text-left hover:bg-zinc-700 transition 
           <% if (activeRoute === '/owners/admin') { %> bg-zinc-700 text-white <% } else { %> text-gray-200 <% } %>">
          Create New Product
        </a>
      </div>
    </div>

    <!-- Main content -->
    <main class="w-3/4 bg-zinc-800 text-white p-8 shadow rounded-lg ml-6">
      <h2 class="text-2xl font-bold mb-6">Create New Product</h2>
      <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data" class="space-y-6">

        <!-- Product Details -->
         <div>
          <h3 class="text-lg font-semibold mb-3">Product Details</h3>
           <label class="block mb-2 font-medium">Upload Product Image</label>
            <input required name="image" type="file" class="mt-2 mb-2 bg-zinc-700 border border-zinc-600 text-white file:bg-blue-600 file:text-white file:rounded file:px-3 file:py-1 rounded w-full">
          <div class="grid grid-cols-2 gap-6">            
            <div>
              <label class="block mb-1 font-medium">Product Name</label>
              <input required name="name" type="text" 
                class="bg-zinc-700 border border-zinc-600 text-white p-2 rounded w-full">
            </div>
            <div>
              <label class="block mb-1 font-medium">Product Price</label>
              <input required name="price" type="text" 
                class="bg-zinc-700 border border-zinc-600 text-white p-2 rounded w-full">
            </div>
            <div>
              <label class="block mb-1 font-medium">Discount</label>
              <input required name="discount" type="text"  
                class="bg-zinc-700 border border-zinc-600 text-white p-2 rounded w-full">
            </div>
          </div>
        </div>

        <!-- Panel Colors -->
        <div>
          <h3 class="text-lg font-semibold mb-3">Panel Details</h3>
          <div class="grid grid-cols-2 gap-6">
            <div>
              <label class="block mb-1 font-medium">Background Color</label>
              <input required name="bgcolor" type="text" value="#F3F8FB" 
                class="bg-zinc-700 border border-zinc-600 text-white p-2 rounded w-full">
            </div>
            <div>
              <label class="block mb-1 font-medium">Panel Color</label>
              <input required name="panelcolor" type="text" value="black" 
                class="bg-zinc-700 border border-zinc-600 text-white p-2 rounded w-full">
            </div>
            <div>
              <label class="block mb-1 font-medium">Text Color</label>
              <input required name="textcolor" type="text" value="white" 
                class="bg-zinc-700 border border-zinc-600 text-white p-2 rounded w-full">
            </div>
          </div>
        </div>


        <!-- Submit Button -->
        <div>
          <input class="hvr px-6 py-2 rounded bg-blue-500 hover:bg-blue-600 text-white cursor-pointer" type="submit" value="Create New Product">
        </div>
      </form>
    </main>
  </div>
</div>

<%- include('./partials/footer') %>
