<%- include('./partials/header') %>
<% if(success.length>0){ %>
        <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
            <span class="inline-block mt-1 mb-1 text-white">
                <%= success %>
            </span>
        </div>
        <% } %>
    <div class="w-full min-h-screen flex items-start px-20 py-20 bg-zinc-900 text-white">

  <!-- Sidebar -->
  <div class="w-[20%] mr-3 flex flex-col items-start bg-zinc-800 rounded-lg p-5 h-fit shadow-md">
    <h3 class="text-xl font-semibold mb-4">Owner Panel</h3>
    <div class="flex flex-col gap-3 w-full">
      <a href="/owners/allproducts"
         class="w-full px-4 py-2 rounded-md text-left hover:bg-zinc-700 transition 
         <% if (activeRoute === '/owners/allproducts') { %> bg-zinc-700 text-white <% } else { %> text-gray-200 <% } %>">
        All Products
      </a>
      <a href="/owners/admin"
         class="w-full px-4 py-2 rounded-md text-left hover:bg-zinc-700 transition 
         <% if (activeRoute === '/owners/admin') { %> bg-zinc-700 text-white <% } else { %> text-gray-200 <% } %>">
        Create New Product
      </a>
    </div>
  </div>

  <!-- Product Grid -->
  <div class="w-[80%] flex flex-wrap gap-6">
    <% products.forEach(function(product){ %>
      <div class="basis-1/4 max-w-[23%] rounded-xl overflow-hidden shadow-lg bg-white">
        <!-- Product Image Section -->
        <div class="w-full h-52 flex items-center justify-center bg-[<%= product.bgcolor %>]">
          <img class="h-[10rem] object-contain" src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
        </div>

        <!-- Product Details -->
        <div class="bg-[<%= product.panelcolor %>] text-[<%= product.textcolor %>] px-4 py-3 flex flex-col gap-2">
          <h3 class="font-semibold text-lg"><%= product.name %></h3>

          <div class="flex justify-between items-center">
            <!-- Price and Discount -->
            <div class="flex flex-col">
              <span class="text-base font-medium">₹ <%= product.price %></span>
              <% if(product.discount > 0){ %>
                <span class="text-xs font-bold text-black bg-green-300 rounded-full px-2 py-0.5 mt-1 w-fit">
                  -<%= ((100 * product.discount) / product.price).toFixed(2) %>% off
                </span>
              <% } else { %>
                <!-- Empty badge space to maintain height -->
                <span class="opacity-0 select-none text-xs font-bold rounded-full px-2 py-0.5 mt-1">.</span>
              <% } %>
            </div>

            <!-- Edit Button -->
            <a href="/owners/editprod/<%= product._id %>" class="w-8 h-8 flex items-center justify-center bg-white rounded-full hover:bg-gray-200 transition">
              <i class="fa-solid fa-pencil text-black"></i>
            </a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

    <%- include('./partials/footer') %>